# 100% free stack -- one vendor, no card required.
# Get key: https://build.nvidia.com -> sign in -> Generate API Key (free, 1,000 credits, no card)

NVIDIA_NIM_API_KEY=
NIM_CHAT_MODEL=meta/llama-3.1-8b-instruct

# auth -- change JWT_SECRET before any real deployment (this default is public in the repo)
JWT_SECRET=dev-secret-change-in-prod

# default ops dashboard login, created by the seed script. Change SEED_STAFF_PASSWORD
# before any real deployment -- these are demo defaults.
SEED_STAFF_USERNAME=staff
SEED_STAFF_PASSWORD=demo

DATABASE_URL=postgresql://stadium:stadium@localhost:5432/stadiumpulse

# comma-separated, no spaces needed but trimmed if present
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# requests/minute per client IP, applies to both navigator and orchestrator
RATE_LIMIT_PER_MINUTE=30

# development | production -- affects log format/verbosity
ENVIRONMENT=development

# app runs without NVIDIA_NIM_API_KEY too (dev-mode stub), just skip translation/reasoning quality
